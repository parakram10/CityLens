# ── OS / editor ──────────────────────────────────────────────
.DS_Store

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/

# ── Model weights — large; recreated via backend/setup.sh ────
*.pt
*.onnx
models/*.pt

# ── Detector training / run artifacts (regenerated) ──────────
backend/detector/outputs/
backend/detector/dataset/
outputs/
dataset/

# ── Large videos — place locally, not committed ──────────────
assets/*.mp4
assets/*.mov
# Root replay clips consumed by the Fleet demo (local only;
# the deployed site falls back to the simulated timeline).
annotated.mp4
source.mp4
screen_grabs/

# NOTE: committed on purpose — the deployed GitHub Pages site depends on them:
#   js/live.js, js/live.json, assets/evidence/*.jpg,
#   backend/pipeline/motion_*.json, detections.json, summary.json, crops/
