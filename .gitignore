# ── OS / editor ──────────────────────────────────────────────
.DS_Store

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/

# ── Model weights — large; recreated via backend/setup.sh ────
*.pt
*.onnx
models/*.pt

# ── Detector training / run artifacts (regenerated) ──────────
backend/detector/outputs/
backend/detector/dataset/
outputs/
dataset/

# ── Large videos — place locally, not committed ──────────────
assets/*.mp4
assets/*.mov
annotated.mp4
source.mp4
screen_grabs/
# Per-run replay clips symlinked into runs/<id>/ — local only; the deployed
# site falls back to each trip's simulated timeline.
runs/*/*.mp4

# NOTE: committed on purpose — the deployed GitHub Pages site depends on them:
#   js/live.js, js/live.json, assets/evidence/*.jpg, backend/pipeline/motion_*.json,
#   runs/index.json (the Fleet manifest) and runs/*/crops/*.jpg (replay thumbnails).
